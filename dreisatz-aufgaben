<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dreisatz-Master Pro</title>
    <style>
        :root {
            --bg: #f3f4f6;
            --card: #ffffff;
            --primary: #4f46e5;
            --secondary: #10b981;
            --accent: #f59e0b;
            --text: #111827;
            --text-light: #6b7280;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            font-family: -apple-system, system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container { width: 100%; max-width: 500px; }

        .card {
            background: var(--card);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            margin-bottom: 16px;
        }

        h1 { font-size: 1.4rem; color: var(--primary); text-align: center; margin-bottom: 20px; font-weight: 800; }

        .nav { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
        
        .nav button {
            padding: 14px;
            border-radius: 14px;
            border: 2px solid #f3f4f6;
            background: #f9fafb;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.95rem;
            color: var(--text-light);
        }
        
        .nav button.active { 
            border-color: var(--primary); 
            color: var(--primary); 
            background: #eef2ff; 
        }

        .display {
            background: #f8fafc;
            padding: 20px;
            border-radius: 18px;
            font-size: 1.1rem;
            line-height: 1.6;
            border: 1px solid #e2e8f0;
            margin-bottom: 16px;
            min-height: 120px;
            text-align: left;
        }

        .hint { 
            font-size: 0.85rem; 
            color: var(--accent); 
            font-weight: bold; 
            margin-bottom: 12px; 
            text-align: center; 
        }

        .input-area { display: flex; flex-direction: column; gap: 12px; }
        
        input {
            width: 100%;
            padding: 16px;
            border-radius: 14px;
            border: 2px solid #e5e7eb;
            font-size: 1.3rem;
            text-align: center;
            appearance: none;
            outline: none;
        }
        
        input:focus { border-color: var(--primary); }

        .btn-check {
            background: var(--secondary);
            color: white;
            padding: 16px;
            border-radius: 14px;
            border: none;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
        }

        .btn-next {
            background: var(--primary);
            color: white;
            padding: 16px;
            border-radius: 14px;
            border: none;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
        }

        #res { display: none; padding: 16px; border-radius: 14px; text-align: center; font-weight: bold; margin-top: 16px; }

        .calc-toggle {
            background: #374151;
            color: white;
            width: 100%;
            padding: 12px;
            border-radius: 14px;
            margin-top: 12px;
            border: none;
            font-weight: 600;
            font-size: 0.9rem;
        }

        #mini-calc {
            display: none;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            background: #1f2937;
            padding: 16px;
            border-radius: 18px;
            margin-top: 12px;
        }

        #mini-calc button {
            padding: 15px 5px;
            border-radius: 10px;
            border: none;
            background: #4b5563;
            color: white;
            font-weight: bold;
            font-size: 1.1rem;
        }

        #calc-screen {
            grid-column: span 4;
            background: #111827;
            color: #10b981;
            padding: 12px;
            text-align: right;
            font-family: 'Courier New', monospace;
            font-size: 1.4rem;
            border-radius: 10px;
            margin-bottom: 8px;
            overflow: hidden;
        }

        footer { 
            text-align: center; 
            margin-top: 24px; 
            padding: 20px; 
            border-top: 1px solid #e5e7eb; 
            width: 100%;
            font-size: 0.9rem;
        }
        
        .contact { color: var(--primary); text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div class="card">
        <h1>Dreisatz-Master</h1>
        
        <div class="nav">
            <button onclick="changeMode('prop', this)" class="active">Proportional (gerade)</button>
            <button onclick="changeMode('anti', this)">Antiproportional (ungerade)</button>
            <button onclick="changeMode('mix', this)">Zusammengesetzt</button>
        </div>

        <div id="quest" class="display">Aufgabe wird erstellt...</div>

        <div class="hint">⚠️ Bitte auf 2 Dezimalstellen runden!</div>

        <div class="input-area">
            <input type="number" id="val" placeholder="0,00" step="0.01">
            <button class="btn-check" onclick="verify()">Ergebnis prüfen</button>
            <button class="btn-next" onclick="next()">Nächste Aufgabe</button>
        </div>

        <div id="res"></div>

        <button class="calc-toggle" onclick="toggleCalc()">Taschenrechner ein-/ausblenden</button>
        <div id="mini-calc">
            <div id="calc-screen">0</div>
            <button onclick="calcIn('7')">7</button><button onclick="calcIn('8')">8</button><button onclick="calcIn('9')">9</button><button onclick="calcIn('/')">÷</button>
            <button onclick="calcIn('4')">4</button><button onclick="calcIn('5')">5</button><button onclick="calcIn('6')">6</button><button onclick="calcIn('*')">×</button>
            <button onclick="calcIn('1')">1</button><button onclick="calcIn('2')">2</button><button onclick="calcIn('3')">3</button><button onclick="calcIn('-')">-</button>
            <button onclick="calcIn('0')">0</button><button onclick="calcIn('.')">,</button><button onclick="calcClear()" style="background: #991b1b">C</button><button onclick="calcIn('+')">+</button>
            <button onclick="calcEval()" style="grid-column: span 4; background: var(--secondary);">=</button>
        </div>
    </div>

    <footer>
        <p>Probleme oder Fragen? Bitte schreiben Sie eine kurze E-Mail, am besten mit Screenshot und kurzer Fehlerbeschreibung.<br>
        <a href="mailto:wijnandts@bk-erkelenz.de" class="contact">Kontakt aufnehmen</a></p>
    </footer>
</div>

<script>
    let currentMode = 'prop';
    let targetValue = 0;
    let calcExpr = "";

    const scenarios = {
        prop: [
            { s: "Für die Herstellung von {a} Ballen Baumwollstoff von je {b} m Länge benötigt man {c} kg Rohbaumwolle. Wie viel kg werden für {d} Ballen von je {e} m Länge benötigt?", f: (a,b,c,d,e) => (c / (a * b)) * (d * e) },
            { s: "Ein Ballen Anzugstoff von {a} m Länge kostet {b} €. Wie viel Euro muss ein Kunde für {c} m dieses Stoffes bezahlen?", f: (a,b,c) => (b/a)*c },
            { s: "Beim Rösten von {a} kg Rohkaffee entsteht ein Röstverlust von {b} kg. Wie viel Rohkaffee derselben Sorte muss ein Kaufmann rösten, der {c} kg Röstkaffee benötigt?", f: (a,b,c) => (a / (a - b)) * c },
            { s: "{a} Meter Stoff mit einer Breite von {b} cm kosten {c} €. Wie viel kosten {d} Meter bei einer Breite von {e} cm?", f: (a,b,c,d,e) => (c / (a * b)) * (d * e) },
            { s: "Die Beteiligung eines Schülers an einer Klassenfahrt wird mit {a} € berechnet. Wie hoch ist der Gesamtbetrag, wenn ursprünglich {b} Schüler teilnehmen wollten, nun aber nur {c} Schüler mitfahren?", f: (a,b,c) => a * c }
        ],
        anti: [
            { s: "Ein Betrieb beschäftigt bei einer {a}-stündigen Arbeitswoche {b} Mitarbeiter. Wie viele Mitarbeiter müssten es bei einer {c}-stündigen Woche sein, um die gleiche Leistung zu erbringen?", f: (a,b,c) => (a*b)/c },
            { s: "Ein Futtervorrat reicht für {a} Tiere genau {b} Tage. Wie viele Tage reicht der Vorrat, wenn der Bestand auf {c} Tiere erhöht wird?", f: (a,b,c) => (a*b)/c },
            { s: "Ein Auto benötigt für eine Strecke {a} Stunden bei einer Geschwindigkeit von {b} km/h. In welcher Zeit schafft es die Strecke bei {c} km/h?", f: (a,b,c) => (a*b)/c },
            { s: "Ein Vorrat an Dieselkraftstoff reicht für {a} Maschinen genau {b} Tage. Wie lange reicht der Vorrat, wenn {c} Maschinen zusätzlich in Betrieb genommen werden?", f: (a,b,c) => (a*b)/(a+c) },
            { s: "Zur Durchführung einer Inventur brauchen {a} Angestellte {b} Tage bei {c} Stunden täglich. Wie viele Stunden täglich müssten {d} Angestellte arbeiten, um die Inventur in {e} Tagen fertigzustellen?", f: (a,b,c,d,e) => (a*b*c)/(d*e) }
        ],
        mix: [
            { s: "{a} Arbeiter errichten in {b} Tagen eine Mauer von {c} m Länge. Wie viele Tage benötigen {d} Arbeiter für eine Mauer von {e} m Länge?", f: (a,b,c,d,e) => (b / (c / a)) * (e / d) },
            { s: "{a} Lkw transportieren in {b} Tagen {c} t Kies. Wie viele Tonnen schaffen {d} Lkw in {e} Tagen?", f: (a,b,c,d,e) => (c / (a * b)) * (d * e) },
            { s: "{a} Maschinen produzieren in {b} Stunden {c} Werkstücke. Wie viele Stunden benötigen {d} Maschinen für {e} Werkstücke?", f: (a,b,c,d,e) => (b / (c / a)) * (e / d) },
            { s: "Ein Graben von {a} m Länge, {b} m Breite und {c} m Tiefe wurde von {d} Arbeitern in {e} Tagen ausgehoben. Wie viele Tage brauchen {f} Arbeiter für einen Graben von {g} m Länge, {h} m Breite und {i} m Tiefe?", f: (a,b,c,d,e,f,g,h,i) => (e / (a*b*c / d)) * (g*h*i / f) },
            { s: "Ein Nahrungsmittelvorrat reicht für {a} Tage, wenn täglich {b} Personen {c} Portionen zu je {d} g erhalten. Wie viele Tage reicht der Vorrat, wenn {e} Personen täglich {f} Portionen zu je {g} g erhalten?", f: (a,b,c,d,e,f,g) => (a * b * c * d) / (e * f * g) }
        ]
    };

    function changeMode(m, btn) {
        currentMode = m;
        document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        next();
    }

    function next() {
        document.getElementById('res').style.display = 'none';
        document.getElementById('val').value = '';
        const list = scenarios[currentMode];
        const sc = list[Math.floor(Math.random() * list.length)];
        
        // Zufallswerte passend zum Szenario
        let a = rand(10, 60), b = rand(2, 40), c = rand(100, 1000), d = rand(5, 50), e = rand(5, 30), f = rand(5, 20), g = rand(50, 200), h = rand(1, 5), i = rand(1, 3);
        
        // Spezialkorrektur für Kaffee-Röstverlust (Aufgabe 4)
        if (sc.s.includes("Röstverlust")) { a = 50; b = 10; c = 160; }
        
        let text = sc.s.replace('{a}', a).replace('{b}', b).replace('{c}', c).replace('{d}', d).replace('{e}', e).replace('{f}', f).replace('{g}', g).replace('{h}', h).replace('{i}', i);
        document.getElementById('quest').innerText = text;
        
        // Berechnungsschnittstelle für verschiedene Parameteranzahlen
        if (sc.s.includes("Nahrungsmittel")) {
             targetValue = sc.f(56, 4, 81, 200, 100, 3, 150); // Beispielwerte nah am Buch
             document.getElementById('quest').innerText = "Ein Vorrat reicht für 56 Tage, wenn täglich 4 Personen 81 Portionen zu je 200g erhalten. Wie viele Tage reicht er für 100 Personen bei täglich 3 Portionen zu je 150g?";
        } else {
             targetValue = (currentMode === 'mix' || sc.s.includes("Stoff") || sc.s.includes("Inventur")) ? sc.f(a,b,c,d,e,f,g,h,i) : sc.f(a,b,c);
        }
    }

    function verify() {
        const user = parseFloat(document.getElementById('val').value.replace(',', '.'));
        const r = document.getElementById('res');
        r.style.display = 'block';
        const rounded = Math.round(targetValue * 100) / 100;
        
        if(!isNaN(user) && Math.abs(user - rounded) < 0.015) {
            r.style.background = "#d1fae5"; r.style.color = "#065f46"; 
            r.innerHTML = "<b>Richtig!</b><br>Das Ergebnis ist " + rounded.toLocaleString('de-DE', {minimumFractionDigits: 2}) + ".";
        } else {
            r.style.background = "#fee2e2"; r.style.color = "#991b1b"; 
            r.innerHTML = "<b>Leider falsch.</b><br>Die richtige Lösung ist " + rounded.toLocaleString('de-DE', {minimumFractionDigits: 2}) + ".";
        }
    }

    function rand(min, max) { return Math.floor(Math.random() * (max - min + 1) + min); }

    function toggleCalc() {
        const c = document.getElementById('mini-calc');
        c.style.display = (window.getComputedStyle(c).display === 'none') ? 'grid' : 'none';
    }

    function calcIn(v) { calcExpr += v; document.getElementById('calc-screen').innerText = calcExpr; }
    function calcClear() { calcExpr = ""; document.getElementById('calc-screen').innerText = "0"; }
    function calcEval() {
        try { 
            let res = eval(calcExpr); 
            calcExpr = Number.isInteger(res) ? res.toString() : res.toFixed(3);
            document.getElementById('calc-screen').innerText = calcExpr.replace('.', ',');
        } catch { document.getElementById('calc-screen').innerText = "Fehler"; calcExpr = ""; }
    }

    window.onload = next;
</script>
</body>
</html>
